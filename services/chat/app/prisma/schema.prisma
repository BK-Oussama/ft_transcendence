generator client {
  provider        = "prisma-client-js" // Add the "-js" suffix
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// Minimal starter table for the Chat developer
model Message {
  id        Int      @id @default(autoincrement())
  content   String
  senderId  Int      // Logical link to Auth User
  roomId    Int      // Logical link to Board/Room
  createdAt DateTime @default(now())
}