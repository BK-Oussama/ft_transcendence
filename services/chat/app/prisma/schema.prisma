generator client {
  provider = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["public"] 
  // URL is intentionally omitted here; it is handled by prisma.config.mjs
}

model Message {
  id         Int      @id @default(autoincrement())
  content    String
  senderId   Int      
  senderName String   
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@schema("public")
}

model Relationship {
  id        Int      @id @default(autoincrement())
  userId    Int      
  friendId  Int      
  status    String   @default("FRIEND") 
  createdAt DateTime @default(now())

  @@unique([userId, friendId])
  @@schema("public")
}