generator client {
  provider        = "prisma-client-js" // Add the "-js" suffix
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// Minimal starter table for the Dashboard developer
model Activity {
  id          Int      @id @default(autoincrement())
  type        String   // e.g., "BOARD_CREATED", "TASK_COMPLETED"
  description String
  createdAt   DateTime @default(now())
}