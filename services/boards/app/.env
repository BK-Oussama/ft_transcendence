POSTGRES_USER=myuser
POSTGRES_PASSWORD=mypassword
POSTGRES_DB=dashboard-db

DATABASE_URL_DOCKER="postgresql://myuser:mypassword@dashboard-db:5432/dashboard-db?schema=public"

# Database connection (Matches service name in docker-compose)
DATABASE_URL="postgresql://user:pass@dashboard-db:5432/dashboard_db?schema=public"

# Example JWT secret for later
JWT_SECRET="super-secret-key-change-me"

