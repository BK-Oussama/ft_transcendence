# Application Port
PORT=443

# Database Connection URL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/project_db?schema=public"

# Authentication
# Use a long, random string for the JWT secret
JWT_ACCESS_SECRET=your_jwt_access_secret_here

# Service Keys
# Comma-separated list of public API keys
PUBLIC_API_KEYS=key1,key2

# Internal Communication
# Secret key for verifying requests between microservices
INTERNAL_SERVICE_SECRET=your_internal_service_secret_here